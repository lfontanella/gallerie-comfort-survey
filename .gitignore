# ---------------------------------------------------------------------------
# System files
# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Temporary files
# ---------------------------------------------------------------------------

*.tmp
*.temp
*.bak
*.backup
*.log

# ---------------------------------------------------------------------------
# Office temporary files
# ---------------------------------------------------------------------------

~$*.xlsx
~$*.xlsm
~$*.xls
~$*.docx
~$*.pptx

# ---------------------------------------------------------------------------
# Private data exports
# ---------------------------------------------------------------------------

*.csv
*.tsv
*.xlsx
*.xlsm

# Allow explicitly anonymized or example spreadsheets if needed
!*example*.xlsx
!*sample*.xlsx
!*template*.xlsx
!*anonymized*.xlsx

# ---------------------------------------------------------------------------
# Credentials and private configuration
# ---------------------------------------------------------------------------

.env
*.env
settings.json
secrets.*
credentials.*
token.*
tokens.*

# ---------------------------------------------------------------------------
# BIM / model files not published in this repository
# ---------------------------------------------------------------------------

*.rvt
*.rfa
*.rte
*.ifc
*.ifczip
*.blend

# ---------------------------------------------------------------------------
# Python / local scripts, if added later
# ---------------------------------------------------------------------------

__pycache__/
*.py[cod]
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Node / web tooling, if added later
# ---------------------------------------------------------------------------

node_modules/
dist/
build/
.cache/
